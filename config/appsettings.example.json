{
  "TiaAgent": {
    "Mode": "Simulator",
    "Mcp": {
      "Enabled": true,
      "Host": "127.0.0.1",
      "Port": 43121,
      "RequireAuthentication": true,
      "RequestTimeoutSeconds": 30,
      "MaximumPayloadBytes": 1048576
    },
    "OpenCode": {
      "Mode": "External",
      "BaseUrl": "http://127.0.0.1:43120",
      "DefaultAgent": "tia-explain",
      "StartupTimeoutSeconds": 20
    },
    "Selections": {
      "LifetimeMinutes": 30
    },
    "Changes": {
      "Enabled": false,
      "ApprovalLifetimeMinutes": 5,
      "RequireBackup": true,
      "CompileAfterApply": true
    },
    "Limits": {
      "MaximumPageSize": 100,
      "MaximumHierarchyDepth": 5,
      "MaximumHierarchyNodes": 500,
      "MaximumBlockSourceBytes": 524288
    }
  }
}
